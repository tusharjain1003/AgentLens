# ============================================================
# web-search-rag — Environment Variables (example)
# Copy to .env and fill in real values.
# ============================================================

# Supabase / Postgres connection string
DATABASE_URL="postgresql://user:password@host:port/dbname"

# LLM providers — at least one required
# DeepSeek V3 is the default (cheaper, no rate limit)
DEEPSEEK_API_KEY="sk-..."
# OpenAI fallback (optional)
OPENAI_API_KEY="sk-proj-..."
# Which provider to use: "deepseek" or "openai"
LLM_PROVIDER="deepseek"

# Tavily — web search URL discovery
TAVILY_API_KEY="tvly-..."

# Jina Reader — content extraction (optional; free tier works without a key)
JINA_API_KEY=""

# LangSmith tracing — off by default, toggled per eval run via --trace on
# Set LANGSMITH_TRACING=true here only if you want all traffic traced.
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY="lsv2_pt_..."
LANGSMITH_PROJECT="weblens"

# App settings
ENVIRONMENT="development"
PORT=8765
LOG_LEVEL="INFO"

# Public mode (anon-session pattern). Set TRUE in production so:
#   • GET /api/sessions returns [] (chat sidebar empty for end users)
#   • Frontend uses sessionStorage for session_id (lost on tab close)
# Keep FALSE in development to see all chats in the sidebar.
PUBLIC_MODE=false

# Frontend build-time flag — mirrors PUBLIC_MODE for the Vite build.
# When true, frontend skips /api/sessions list and uses sessionStorage.
# This is consumed by Vite at build time, not by Python.
# VITE_PUBLIC_MODE=false
